# Node.js
node_modules/
npm-debug.log*

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Environment files
.env

# Terraform local state and provider cache - never commit these; they are
# machine-local and regenerated by `terraform init`. The lock file
# (.terraform.lock.hcl) IS meant to be committed, so it is not ignored here.
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
.py
